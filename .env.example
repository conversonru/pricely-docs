# ─────────────────────────────────────────────────────────────
# Pricely — шаблон переменных окружения
# Скопируй в .env.local и заполни реальными значениями
# ─────────────────────────────────────────────────────────────

# Supabase (self-hosted на VPS)
# Адрес API: http://{SERVER_IP}:8000
# Ключи берёшь из /opt/pricely/.env на сервере
NEXT_PUBLIC_SUPABASE_URL=http://72.56.5.159:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telegram Bot (заполнить в День 4)
# Получи у @BotFather командой /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Prodamus (заполнить в День 7)
# Личный кабинет: prodamus.ru
PRODAMUS_SECRET_KEY=your_prodamus_secret_key

# Домен приложения
# Локально: http://localhost:3000
# На Vercel: https://pricely.ru
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=pricely.ru
