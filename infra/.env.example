############################################################
# Pricely — Self-hosted Supabase на Timeweb VPS
# Скопируй в .env и заполни СВОИМИ значениями
# НИКОГДА не коммить .env в git!
############################################################

# ── Домены ────────────────────────────────────────────────
# IP или домен твоего VPS (например: 194.87.xxx.xxx или db.pricely.ru)
API_EXTERNAL_URL=http://YOUR_VPS_IP:8000
SITE_URL=https://pricely.ru
ADDITIONAL_REDIRECT_URLS=

# ── Пароли и секреты ──────────────────────────────────────
# Придумай надёжный пароль для PostgreSQL (мин. 16 символов)
POSTGRES_PASSWORD=your-super-secret-postgres-password-min-16-chars

# JWT Secret — минимум 32 символа, можно сгенерировать:
# openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-min-32-chars-long

# Время жизни JWT токена (в секундах)
JWT_EXPIRY=3600

# Realtime ключ — любая случайная строка 64+ символа
REALTIME_SECRET_KEY_BASE=your-realtime-secret-key-base-64-chars

# ── Ключи Supabase (генерируются из JWT_SECRET) ───────────
# Используй генератор: https://supabase.com/docs/guides/self-hosting#api-keys
# Или запусти: node infra/generate-keys.js
ANON_KEY=your-anon-key-here
SERVICE_ROLE_KEY=your-service-role-key-here

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-dashboard-password

# ── SMTP (для email-подтверждений) ────────────────────────
# Можно использовать Yandex или бесплатный Resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_ADMIN_EMAIL=noreply@pricely.ru
ENABLE_EMAIL_AUTOCONFIRM=true

# ── Логи ──────────────────────────────────────────────────
LOGFLARE_API_KEY=your-logflare-api-key
